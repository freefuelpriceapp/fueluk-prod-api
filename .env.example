# FreeFuelPrice API - Environment Variables Example
# Copy this file to .env for local/non-production development
# DO NOT commit .env to version control

# Server
PORT=3000

# Database (local/non-production)
# When DB_HOST is set, secrets.js will skip AWS Secrets Manager
DB_HOST=localhost
DB_PORT=5432
DB_NAME=fuelapp
DB_USER=postgres
DB_PASS=your_local_password
DB_SSL=false

# AWS (leave blank for local mode - DB_HOST takes precedence)
# AWS_REGION=eu-west-2
# DB_SECRET_NAME=fuelapp/prod-db-credentials

# UK Gov Fuel Finder API (Sprint 15)
# Credentials must be obtained from the UK Government Fuel Finder onboarding.
# NEVER commit real values. The API blocks non-UK datacenter IPs — production
# traffic is routed through a UK-based Lambda proxy (see FUEL_FINDER_PROXY_URL).
# FEATURE_FUEL_FINDER=false
# FUEL_FINDER_CLIENT_ID=
# FUEL_FINDER_CLIENT_SECRET=
# FUEL_FINDER_BASE_URL=https://www.fuel-finder.service.gov.uk
# FUEL_FINDER_STATION_CRON=15 3 * * *
# FUEL_FINDER_PRICE_CRON=*/5 * * * *
# FUEL_FINDER_REQUEST_DELAY_MS=5000
# FUEL_FINDER_RUN_ON_BOOT=false
# Lambda proxy (eu-west-2). When set, all Fuel Finder traffic (token,
# stations, prices) is routed through the proxy instead of direct to
# fuel-finder.service.gov.uk. Required in production — the upstream API
# blocks our ECS region.
# FUEL_FINDER_PROXY_URL=
# FUEL_FINDER_PROXY_SECRET=

# Vehicle Spec Enrichment (checkcardetails.co.uk) — promoted to standard
# capability. Default ON; the service is a safe no-op without the API key.
# Set FEATURE_VEHICLE_SPEC_ENRICHMENT=false to explicitly disable.
# CHECKCARDETAILS_API_KEY=
# FEATURE_VEHICLE_SPEC_ENRICHMENT=true
